# ============================================================
# Transistor Electrical Quantities
# ============================================================

# ------------------------------------------------------------
# Voltages around the Transistor
# ------------------------------------------------------------
V_C = float(analysis.nodes['colect'][0])   # Collector voltage [V]
V_E = float(analysis.nodes['emeteur'][0])     # Emitter voltage [V]
V_CE = V_C - V_E                                # VCE voltage [V]

print("=== Transistor Voltages ===")
print(f"Vc   = {V_C:.3f} V")
print(f"Ve   = {V_E:.3f} V")
print(f"Vce  = {V_CE:.3f} V")

# ------------------------------------------------------------
# Emitter Current Estimation
# ------------------------------------------------------------
I_in = -float(analysis.VIN[0])                  # Current supplied by VIN [A]
I_Rc = (V_C - V_E) / 1e3                        # Current through RC = 1 kΩ [A]
I_E  = I_in - I_Rc                              # Approx. emitter current [A]

print("\n=== Transistor Currents ===")
print(f"Ie   = {I_E*1e3:.3f} mA")

# ------------------------------------------------------------
# Power Dissipation in the Transistor
# ------------------------------------------------------------
P_Q = V_CE * I_E                                # Power P = VCE × IE [W]

print("\n=== Transistor Power ===")
print(f"Pq   = {P_Q*1e3:.3f} mW")

# ============================================================
# End of Electrical Quantities
# ============================================================

